{
  "name": "curator",
  "version": "0.1.27",
  "description": "Archive Curator — dedup + reorg tool",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm run build:sidecar && pnpm run rebuild:electron && electron-vite build && electron-builder --win nsis",
    "build:portable": "pnpm run build:sidecar && pnpm run rebuild:electron && electron-vite build && electron-builder --win portable",
    "build:sidecar": "powershell -ExecutionPolicy Bypass -File scripts/build-sidecar.ps1",
    "rebuild:node": "pnpm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "test": "pnpm run rebuild:node && vitest run",
    "test:e2e": "pnpm run rebuild:electron && electron-vite build && playwright test",
    "test:py": "python\\.venv\\Scripts\\python.exe -m pytest -q",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "fetch-bins": "powershell -ExecutionPolicy Bypass -File scripts/fetch-binaries.ps1",
    "release:win": "pnpm run build:sidecar && pnpm run rebuild:electron && electron-vite build && electron-builder --win nsis --publish always",
    "ship:win": "powershell -ExecutionPolicy Bypass -File scripts/ship-update.ps1"
  },
  "dependencies": {
    "better-sqlite3": "11.3.0",
    "electron-updater": "^6.8.3",
    "react-router-dom": "6.26.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "1.47.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "22.5.4",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.20",
    "electron": "32.0.1",
    "electron-builder": "25.0.5",
    "electron-vite": "2.3.0",
    "jsdom": "^29.0.2",
    "playwright": "1.47.0",
    "postcss": "8.4.45",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "vite": "5.4.3",
    "vitest": "2.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.ionut.curator",
    "productName": "Curator",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist-sidecar",
        "to": "sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "numarulunu",
        "repo": "curator",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "Curator-Setup-${version}.exe",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "Curator-portable.exe"
    }
  }
}
